{
  "name": "corgi",
  "displayName": "corgi",
  "publisher": "corgi",
  "description": "corgi-compose.yml autocomplete + validation, a corgi runner, and an AI assistant (@corgi chat + Copilot agent tools) for VS Code",
  "version": "1.15.15",
  "license": "MIT",
  "repository": "https://github.com/Andriiklymiuk/corgi_vscode_extension",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Linters",
    "Snippets",
    "AI",
    "Chat",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:yml",
    "onLanguage:yaml",
    "workspaceContains:corgi-compose*.yml",
    "workspaceContains:corgi-compose*.yaml",
    "workspaceContains:corgi-*.yml",
    "workspaceContains:corgi-*.yaml",
    "workspaceContains:corgi-*.json",
    "onChatParticipant:corgi.assistant"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "corgi.assistant",
        "name": "corgi",
        "fullName": "Corgi",
        "description": "Scaffold, explain, and debug your corgi-compose.yml stack",
        "isSticky": true,
        "commands": [
          {
            "name": "new",
            "description": "Scaffold a corgi-compose.yml from a description"
          },
          {
            "name": "explain",
            "description": "Explain the current corgi-compose.yml"
          },
          {
            "name": "debug",
            "description": "Diagnose why services aren't healthy (runs doctor + status)"
          }
        ]
      }
    ],
    "languageModelTools": [
      {
        "name": "corgi-status",
        "displayName": "Corgi: stack status",
        "modelDescription": "Health and status of the running corgi stack (each service/db, port, running/crashed/stopped) as JSON. Read-only.",
        "tags": ["corgi"],
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "corgiStatus",
        "icon": "$(pulse)",
        "inputSchema": { "type": "object", "properties": {} }
      },
      {
        "name": "corgi-doctor",
        "displayName": "Corgi: preflight check",
        "modelDescription": "Preflight the corgi project as JSON: required tools installed, Docker up, ports free. Read-only.",
        "tags": ["corgi"],
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "corgiDoctor",
        "icon": "$(check)",
        "inputSchema": { "type": "object", "properties": {} }
      },
      {
        "name": "corgi-validate",
        "displayName": "Corgi: validate compose",
        "modelDescription": "Validate corgi-compose.yml semantics (dangling deps, cycles, unknown driver, port conflicts) as JSON. Read-only.",
        "tags": ["corgi"],
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "corgiValidate",
        "icon": "$(verified)",
        "inputSchema": { "type": "object", "properties": {} }
      },
      {
        "name": "corgi-list",
        "displayName": "Corgi: list services",
        "modelDescription": "List the services and db_services defined in corgi-compose.yml as JSON. Read-only.",
        "tags": ["corgi"],
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "corgiList",
        "icon": "$(list-unordered)",
        "inputSchema": { "type": "object", "properties": {} }
      },
      {
        "name": "corgi-run",
        "displayName": "Corgi: run stack",
        "modelDescription": "Start all db_services and services in the background (corgi run --detach) and return the run-state as JSON. Has side effects; asks for confirmation.",
        "tags": ["corgi"],
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "corgiRun",
        "icon": "$(play)",
        "inputSchema": { "type": "object", "properties": {} }
      }
    ],
    "viewsWelcome": [
      {
        "view": "corgiTreeView",
        "contents": "Corgi cli is not installed.\nInstall corgi to get started. It relies on [Homebrew](https://brew.sh), so make sure it is installed too.\n[$(cloud-download)Install Corgi](command:corgi.installWithHomebrew)\nYou can also check corgi cli repo for more info.\n[$(github-alt)Corgi repo](https://github.com/Andriiklymiuk/corgi)\n",
        "when": "corgiNotInstalled"
      }
    ],
    "keybindings": [
      {
        "key": "ctrl+c",
        "command": "corgi.stop",
        "when": "terminalFocus"
      }
    ],
    "commands": [
      {
        "command": "corgi.run",
        "title": "Corgi run",
        "icon": "$(debug-start)"
      },
      {
        "command": "corgi.runOmitBeforeStart",
        "title": "Corgi run, but omit beforeStart",
        "icon": "$(run-below)"
      },
      {
        "command": "corgi.init",
        "title": "Corgi init (do cloning, if needed, folder creations, etc)"
      },
      {
        "command": "corgi.pull",
        "title": "Corgi pull (pull changes from all repos)"
      },
      {
        "command": "corgi.docs",
        "title": "Show corgi docs"
      },
      {
        "command": "corgi.help",
        "title": "Show corgi help"
      },
      {
        "command": "corgi.stop",
        "title": "Corgi stop",
        "icon": "$(debug-stop)"
      },
      {
        "command": "corgi.create",
        "title": "Corgi create"
      },
      {
        "command": "corgi.doctor",
        "title": "Doctor corgi, check for required (if all programs installed, etc)"
      },
      {
        "command": "corgi.doctorFromRoot",
        "title": "Doctor corgi, check for required from Workspace Root"
      },
      {
        "command": "corgi.doctorFromRoot",
        "title": "Doctor corgi, check for required from Workspace Root"
      },
      {
        "command": "corgi.runFromRoot",
        "title": "Corgi run from root",
        "icon": "$(debug-start)"
      },
      {
        "command": "corgi.runOmitBeforeStartFromRoot",
        "title": "Corgi run from root, but omit beforeStart",
        "icon": "$(run-below)"
      },
      {
        "command": "corgi.reload",
        "title": "Reload extension",
        "icon": "$(refresh)"
      },
      {
        "command": "corgi.createFromRoot",
        "title": "Corgi create from root"
      },
      {
        "command": "corgi.forkFromRoot",
        "title": "Corgi fork repo from root"
      },
      {
        "command": "corgi.pullFromRoot",
        "title": "Corgi pull from Workspace Root"
      },
      {
        "command": "corgi.initFromRoot",
        "title": "Corgi init from Workspace Root"
      },
      {
        "command": "corgi.db",
        "title": "Corgi db"
      },
      {
        "command": "corgi.dbFromRoot",
        "title": "Corgi db from Workspace Root"
      },
      {
        "command": "corgi.dbUp",
        "title": "Corgi up all databases"
      },
      {
        "command": "corgi.dbUpFromRoot",
        "title": "Corgi up all databases from Workspace Root"
      },
      {
        "command": "corgi.dbDown",
        "title": "Corgi down all databases"
      },
      {
        "command": "corgi.dbDownFromRoot",
        "title": "Corgi down all databases from Workspace Root"
      },
      {
        "command": "corgi.dStop",
        "title": "Corgi stop all databases"
      },
      {
        "command": "corgi.dbStopFromRoot",
        "title": "Corgi stop all databases from Workspace Root"
      },
      {
        "command": "corgi.dbSeed",
        "title": "Corgi seed all databases"
      },
      {
        "command": "corgi.dbSeedFromRoot",
        "title": "Corgi seed all databases from Workspace Root"
      },
      {
        "command": "corgi.installWithHomebrew",
        "title": "Corgi install with Homebrew"
      },
      {
        "command": "corgi.downloadExample",
        "title": "Download"
      },
      {
        "command": "corgi.runExample",
        "title": "Download and run"
      },
      {
        "command": "corgi.forkExample",
        "title": "Fork example to your repo"
      },
      {
        "command": "corgi.openLink",
        "title": "Open example link"
      },
      {
        "command": "corgi.clean",
        "title": "Clean"
      },
      {
        "command": "corgi.cleanFromRoot",
        "title": "Clean"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "corgi",
          "title": "Corgi",
          "icon": "resources/activityBarIcon.png"
        }
      ]
    },
    "views": {
      "corgi": [
        {
          "id": "corgiTreeView",
          "name": "Woof"
        }
      ]
    },
    "menus": {
      "editor/title": [
        {
          "command": "corgi.run",
          "group": "navigation",
          "when": "resourceFilename =~ /corgi-*.*\\.y(a)?ml/"
        },
        {
          "command": "corgi.stop",
          "group": "navigation",
          "when": "resourceFilename =~ /corgi-*.*\\.y(a)?ml/"
        }
      ],
      "view/title": [
        {
          "command": "corgi.runFromRoot",
          "when": "view == corgiTreeView",
          "group": "navigation"
        },
        {
          "command": "corgi.stop",
          "when": "view == corgiTreeView",
          "group": "navigation"
        },
        {
          "command": "corgi.reload",
          "when": "view == corgiTreeView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "corgi.runExample",
          "when": "view == corgiTreeView && viewItem == example"
        },
        {
          "command": "corgi.downloadExample",
          "when": "view == corgiTreeView && viewItem == example"
        },
        {
          "command": "corgi.openLink",
          "when": "view == corgiTreeView && viewItem == example"
        },
        {
          "command": "corgi.forkExample",
          "when": "view == corgiTreeView && viewItem == example"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "build:vsce": "vsce package --no-dependencies",
    "publish:vsce": "vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "20.2.5",
    "@types/vscode": "^1.95.0",
    "@vscode/test-electron": "^2.3.2",
    "copy-webpack-plugin": "11.0.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "ts-loader": "^9.4.3",
    "typescript": "^5.1.3",
    "webpack": "^5.85.0",
    "webpack-cli": "^5.1.1"
  },
  "dependencies": {
    "ajv": "8.12.0",
    "yaml": "2.3.1"
  }
}